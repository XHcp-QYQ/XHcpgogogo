# INP 测试环境
BASE_URL=https://testdm-inp.jinkosolar.com

# 登录账号
TEST_ACCOUNT=YYTestDealer1124
TEST_PASSWORD=Reset2026DM

# 图形验证码每次进入登录页都会变化
# ocr：本地 tesseract 自动识别后按大写填入；失败回退 prompt（TTY）或 manual（非 TTY）
# manual：打开有头浏览器后由人工在页面中输入验证码，脚本检测到输入后自动点击登录
# prompt：脚本保存验证码图片并在交互式终端中提示输入；非交互运行会失败并给出图片路径
# env：仅用于验证码固定的特殊环境，读取 GRAPHIC_CODE（CI 使用）
CAPTCHA_MODE=ocr
CAPTCHA_PROMPT_TIMEOUT_MS=120000
GRAPHIC_CODE=

# 下单商品与数量
PRODUCT_ROW_NAME=JKM620N-72HL4-V JKM620N-72HL4
PURCHASE_QTY=100

# 收货地址行关键字
ADDRESS_ROW_NAME=chen bin chen bin 1 1

# 付款条件/付款方式
PAYMENT_TERM=%DP+90%BP
FIRST_PAYMENT_METHOD=T/T
BALANCE_ROW_NAME=90% 55,710.000000 Balance
BALANCE_PAYMENT_METHOD=L/C

# 交期日期选择；同一天可能在日期面板出现多次，用索引控制 nth()
DELIVERY_DAY=30
DELIVERY_DAY_INDEX=1

# 脚本文本中给出的目标订单号；为空时只进入订单列表，不强制打开详情
ORDER_NUMBER=JKINPTEST2026Q36630DM

# 本地调试可设为 false 打开浏览器界面
HEADLESS=false
WORKERS=1
